# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored; this example file is safe to commit.
#
# Expo inlines any var prefixed EXPO_PUBLIC_* into the JS bundle at build
# time, so treat CODER_KEY as low-secret (fine for a personal/local tool,
# not for a published app).

# Base URL of the another_bridge server.
#   iOS simulator : http://localhost:8000  (shares the Mac's network)
#   Android emu   : http://10.0.2.2:8000   (host loopback alias)
#   real phone    : http://<your-mac-LAN-IP>:8000  (e.g. Tailscale IP)
EXPO_PUBLIC_BRIDGE_URL=http://localhost:8000

# Must match ANOTHER_CODER_API_KEY in the bridge's .env (sent as X-Coder-Key).
EXPO_PUBLIC_CODER_KEY=replace-with-your-bridge-api-key

# Optional: OpenAI API key for the cloud voice transcription engine.
# Voice input works without it — the default engine is Apple's on-device
# speech recognition, and on-device Whisper is available as a one-time
# model download from the in-app settings. Set this only if you pick the
# OpenAI engine (or want it as a fallback). Rebuild after changing it.
EXPO_PUBLIC_OPENAI_API_KEY=
